[Unit]
Description=Hermes BTC scheduler service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/hermes_btc_agent_v2
EnvironmentFile=/opt/hermes_btc_agent_v2/.env
ExecStart=/opt/hermes_btc_agent_v2/.venv/bin/python -m scripts.run_scheduler
Restart=always
RestartSec=10
User=hermes
Group=hermes

[Install]
WantedBy=multi-user.target
